<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:PersonaX.UI.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PersonaX.UI.Pages.LockPage"
             x:DataType="pageModels:LockPageModel"
             x:Name="LockPageRoot"
             Title="Unlock"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference LockPageRoot}, x:DataType=ContentPage}"
                EventName="Appearing"                
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid Padding="{StaticResource LayoutPadding}" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Logo/Title Area -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="Center">
            <Label Text="🔒" FontSize="48" HorizontalOptions="Center" />
            <Label Text="{Binding ShowSetupMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='Setup PIN|Enter PIN'}" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- PIN Entry (Setup Mode) -->
        <VerticalStackLayout Grid.Row="2" Spacing="15" IsVisible="{Binding ShowSetupMode}">
            <Entry Placeholder="Enter new PIN (min 4 characters)"
                   Text="{Binding Pin}"
                   IsPassword="True"
                   ReturnType="Next"
                   MinimumHeightRequest="44"
                   SemanticProperties.Description="Enter new PIN" />

            <Entry Placeholder="Confirm PIN"
                   Text="{Binding ConfirmPin}"
                   IsPassword="True"
                   ReturnType="Done"
                   ReturnCommand="{Binding UnlockCommand}"
                   MinimumHeightRequest="44"
                   SemanticProperties.Description="Confirm PIN" />
        </VerticalStackLayout>

        <!-- PIN Entry (Unlock Mode) -->
        <Entry Grid.Row="2" 
               Placeholder="Enter PIN"
               Text="{Binding Pin}"
               IsPassword="True"
               ReturnType="Done"
               ReturnCommand="{Binding UnlockCommand}"
               IsVisible="{Binding ShowSetupMode, Converter={StaticResource InvertedBoolConverter}}"
               MinimumHeightRequest="44"
               SemanticProperties.Description="Enter PIN" />

        <!-- Error Message -->
        <Label Grid.Row="3" 
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"
               HorizontalOptions="Center" />

        <!-- Failed Attempts Counter -->
        <Label Grid.Row="4" 
               Text="{Binding FailedAttempts, StringFormat='Failed attempts: {0}'}"
               IsVisible="{Binding ShowSetupMode, Converter={StaticResource InvertedBoolConverter}}"
               HorizontalOptions="Center"
               FontSize="12"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />

        <!-- Unlock Button -->
        <Button Grid.Row="5" 
                Text="{Binding ShowSetupMode, Converter={StaticResource BoolToObjectConverter}, ConverterParameter='Create PIN|Unlock'}"
                Command="{Binding UnlockCommand}"
                IsEnabled="{Binding IsUnlocking, Converter={StaticResource InvertedBoolConverter}}"
                MinimumHeightRequest="{OnIdiom 44,Desktop=60}"
                SemanticProperties.Description="Unlock button" />
    </Grid>
</ContentPage>
