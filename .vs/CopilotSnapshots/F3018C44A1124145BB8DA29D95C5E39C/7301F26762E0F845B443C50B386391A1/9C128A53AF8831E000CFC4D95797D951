namespace PersonaX.UI.Services
{
    /// <summary>
    /// Service for secure key storage and management.
    /// Handles PIN-based key derivation, master key storage, and biometric unlock.
    /// </summary>
    public interface IKeyStoreService
    {
        /// <summary>
        /// Checks if the app has been initialized with a PIN.
        /// </summary>
        Task<bool> IsInitializedAsync();

        /// <summary>
        /// Initializes the key store with a user-provided PIN.
        /// Generates salt, derives master key via PBKDF2, and stores encrypted key in SecureStorage.
        /// </summary>
        Task InitializeAsync(string pin);

        /// <summary>
        /// Verifies the provided PIN and unlocks the master key.
        /// </summary>
        Task<bool> UnlockWithPinAsync(string pin);

        /// <summary>
        /// Attempts to unlock using biometric authentication (if available and enabled).
        /// </summary>
        Task<bool> UnlockWithBiometricsAsync();

        /// <summary>
        /// Locks the app by clearing the in-memory master key.
        /// </summary>
        Task LockAsync();

        /// <summary>
        /// Gets the database password (derived from master key).
        /// Returns null if app is locked.
        /// </summary>
        Task<string?> GetDatabasePasswordAsync();

        /// <summary>
        /// Gets the file encryption key (derived from master key).
        /// Returns null if app is locked.
        /// </summary>
        Task<byte[]?> GetFileEncryptionKeyAsync();

        /// <summary>
        /// Checks if biometric authentication is available on the device.
        /// </summary>
        Task<bool> IsBiometricsAvailableAsync();

        /// <summary>
        /// Enables or disables biometric unlock.
        /// </summary>
        Task SetBiometricsEnabledAsync(bool enabled);
    }
}
