<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:PersonaX.UI.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="PersonaX.UI.Pages.PeopleDetailPage"
             x:DataType="pageModels:PeopleDetailPageModel"
             x:Name="PeopleDetailRoot"
             Title="Person">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference PeopleDetailRoot}, x:DataType=ContentPage}"
                EventName="Appearing"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Delete"
                     Command="{Binding DeleteCommand}"
                     IconImageSource="{StaticResource IconDelete}"
                     SemanticProperties.Description="Delete person" />
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Hint="First name">
                    <Entry Text="{Binding FirstName}" SemanticProperties.Description="First name" />
                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Last name">
                    <Entry Text="{Binding LastName}" SemanticProperties.Description="Last name" />
                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Email">
                    <Entry Text="{Binding Email}" Keyboard="Email" SemanticProperties.Description="Email" />
                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Phone number">
                    <Entry Text="{Binding PhoneNumber}" Keyboard="Telephone" SemanticProperties.Description="Phone number" />
                </sf:SfTextInputLayout>

                <Label Text="Date of birth" Style="{StaticResource Title3}" />
                <DatePicker Date="{Binding DateOfBirth}" />

                <Label Text="Notes" Style="{StaticResource Title3}" />
                <Editor Text="{Binding Notes}" AutoSize="TextChanges" MinimumHeightRequest="120" SemanticProperties.Description="Notes" />

                <Button Text="Save"
                        Command="{Binding SaveCommand}"
                        MinimumHeightRequest="{OnIdiom 44,Desktop=60}"
                        SemanticProperties.Description="Save person" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
