using Microsoft.Extensions.Logging;

namespace PersonaX.UI.Services
{
    /// <summary>
    /// Implementation of app lock management with auto-lock and retry counting.
    /// </summary>
    public class LockService : ILockService
    {
        private const string FailedAttemptsKey = "lock_failed_attempts";
        private const string WipeEnabledKey = "lock_wipe_enabled";
        private const string MaxAttemptsKey = "lock_max_attempts";

        private readonly IKeyStoreService _keyStoreService;
        private readonly ILogger<LockService> _logger;
        private System.Timers.Timer? _autoLockTimer;
        private bool _isLocked = true;
        private int _failedAttempts = 0;

        public bool IsLocked => _isLocked;
        public int FailedAttempts => _failedAttempts;
        public int MaxFailedAttempts { get; set; } = 0; // Disabled by default
        public int AutoLockTimeoutMinutes { get; set; } = 5;

        public event EventHandler? Locked;
        public event EventHandler? Unlocked;

        public LockService(IKeyStoreService keyStoreService, ILogger<LockService> logger)
        {
            _keyStoreService = keyStoreService;
            _logger = logger;

            // Load persisted failed attempts
            LoadFailedAttempts();
        }

        public async Task<bool> UnlockWithPinAsync(string pin)
        {
            if (string.IsNullOrEmpty(pin))
                return false;

            try
            {
                var unlocked = await _keyStoreService.UnlockWithPinAsync(pin);

                if (unlocked)
                {
                    _isLocked = false;
                    _failedAttempts = 0;
                    await SaveFailedAttemptsAsync();
                    StartAutoLockTimer();
                    Unlocked?.Invoke(this, EventArgs.Empty);
                    _logger.LogInformation("App unlocked successfully");
                    return true;
                }
                else
                {
                    await HandleFailedAttemptAsync();
                    return false;
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error during PIN unlock");
                await HandleFailedAttemptAsync();
                return false;
            }
        }

        public async Task<bool> UnlockWithBiometricsAsync()
        {
            try
            {
                var unlocked = await _keyStoreService.UnlockWithBiometricsAsync();

                if (unlocked)
                {
                    _isLocked = false;
                    _failedAttempts = 0;
                    await SaveFailedAttemptsAsync();
                    StartAutoLockTimer();
                    Unlocked?.Invoke(this, EventArgs.Empty);
                    _logger.LogInformation("App unlocked with biometrics");
                    return true;
                }

                return false;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error during biometric unlock");
                return false;
            }
        }

        public async Task LockAsync()
        {
            if (_isLocked)
                return;

            _isLocked = true;
            StopAutoLockTimer();
            await _keyStoreService.LockAsync();
            Locked?.Invoke(this, EventArgs.Empty);
            _logger.LogInformation("App locked");
        }

        public void NotifyUserActivity()
        {
            if (_isLocked)
                return;

            // Reset auto-lock timer
            StopAutoLockTimer();
            StartAutoLockTimer();
        }

        public void StartAutoLockTimer()
        {
            if (_autoLockTimer != null)
                return;

            _autoLockTimer = new System.Timers.Timer(AutoLockTimeoutMinutes * 60 * 1000);
            _autoLockTimer.Elapsed += async (s, e) =>
            {
                await LockAsync();
            };
            _autoLockTimer.AutoReset = false;
            _autoLockTimer.Start();

            _logger.LogDebug($"Auto-lock timer started ({AutoLockTimeoutMinutes} minutes)");
        }

        public void StopAutoLockTimer()
        {
            if (_autoLockTimer != null)
            {
                _autoLockTimer.Stop();
                _autoLockTimer.Dispose();
                _autoLockTimer = null;
            }
        }

        public void ResetFailedAttempts()
        {
            _failedAttempts = 0;
            SaveFailedAttemptsAsync().FireAndForget();
        }

        public async Task WipeDataAsync()
        {
            var wipeEnabled = Preferences.Get(WipeEnabledKey, false);
            if (!wipeEnabled)
            {
                _logger.LogWarning("Wipe requested but not enabled");
                return;
            }

            _logger.LogCritical("PERFORMING DATA WIPE due to max failed attempts");

            try
            {
                // Delete PII database
                if (File.Exists(Data.Constants.PiiDatabasePath))
                    File.Delete(Data.Constants.PiiDatabasePath);

                // Delete media files
                if (Directory.Exists(Data.Constants.MediaRootPath))
                    Directory.Delete(Data.Constants.MediaRootPath, true);

                // Delete exports
                if (Directory.Exists(Data.Constants.ExportPath))
                    Directory.Delete(Data.Constants.ExportPath, true);

                // Clear secure storage
                SecureStorage.RemoveAll();
                Preferences.Clear();

                _logger.LogInformation("Data wipe completed");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error during data wipe");
            }
        }

        private async Task HandleFailedAttemptAsync()
        {
            _failedAttempts++;
            await SaveFailedAttemptsAsync();

            _logger.LogWarning($"Failed unlock attempt {_failedAttempts}/{MaxFailedAttempts}");

            if (MaxFailedAttempts > 0 && _failedAttempts >= MaxFailedAttempts)
            {
                await WipeDataAsync();
            }
        }

        private void LoadFailedAttempts()
        {
            _failedAttempts = Preferences.Get(FailedAttemptsKey, 0);
            MaxFailedAttempts = Preferences.Get(MaxAttemptsKey, 0);
        }

        private async Task SaveFailedAttemptsAsync()
        {
            Preferences.Set(FailedAttemptsKey, _failedAttempts);
            await Task.CompletedTask;
        }
    }

    /// <summary>
    /// Extension for fire-and-forget async calls (from existing code pattern).
    /// </summary>
    public static class TaskExtensions
    {
        public static void FireAndForget(this Task task)
        {
            task.ContinueWith(t =>
            {
                if (t.IsFaulted && t.Exception != null)
                {
                    // Log exception if needed
                    Console.WriteLine(t.Exception);
                }
            }, TaskScheduler.Default);
        }
    }
}
